# PAL MCP Server — pal-steamline fork
# Copy this file to .env and fill in your values.
#
# Two providers are used:
#   Custom API  — primary, fast; hosts the mimo model
#   OpenRouter  — secondary; hosts gemini, gpt, qwen
#
# At minimum you need one provider configured.

# ---------------------------------------------------------------------------
# Custom API (primary provider — mimo alias)
# ---------------------------------------------------------------------------
# OpenAI-compatible endpoint. Use any vLLM / local Ollama / hosted endpoint.
# Leave CUSTOM_API_KEY empty if the endpoint requires no auth (e.g. Ollama).
CUSTOM_API_URL=https://your-custom-endpoint.com/v1
CUSTOM_API_KEY=your-custom-api-key

# ---------------------------------------------------------------------------
# Mistral (optional provider — mistral alias)
# ---------------------------------------------------------------------------
MISTRAL_API_KEY=your-mistral-api-key

# ---------------------------------------------------------------------------
# OpenRouter (secondary provider — gemini, gpt, qwen aliases)
# ---------------------------------------------------------------------------
OPENROUTER_API_KEY=your-openrouter-key

# ---------------------------------------------------------------------------
# Model routing
# ---------------------------------------------------------------------------
# DEFAULT_MODEL: alias used when no model is specified in a tool call.
# Available aliases: mimo (default), gemini, gpt, qwen, mistral
DEFAULT_MODEL=mimo

# EXPERT_MODEL: alias used for the validation pass in workflow tools
# (thinkdeep, debug, codereview, consensus). Set to empty to disable.
EXPERT_MODEL=gemini

# Restrict OpenRouter to specific models (comma-separated full model names).
# Leave unset to allow all models in conf/openrouter_models.json.
# The three aliased models from the fork:
OPENROUTER_ALLOWED_MODELS=google/gemini-3.1-pro-preview,openai/gpt-5.4,qwen/qwen3.6-plus

# ---------------------------------------------------------------------------
# Optional settings
# ---------------------------------------------------------------------------

# Conversation thread lifetime and depth
CONVERSATION_TIMEOUT_HOURS=24
MAX_CONVERSATION_TURNS=40

# Disable individual tools (version and listmodels cannot be disabled).
# The fork removes 9 upstream tools; all remaining tools are enabled by default.
# Example: DISABLED_TOOLS=apilookup,consensus
DISABLED_TOOLS=

# Language for AI responses (e.g. fr-FR, zh-CN). Leave empty for English.
# LOCALE=

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Default thinking depth for thinkdeep tool: minimal, low, medium, high, max
DEFAULT_THINKING_MODE_THINKDEEP=high

# Custom API timeout tuning (seconds). Useful for slow or local models.
# CUSTOM_CONNECT_TIMEOUT=45.0
# CUSTOM_READ_TIMEOUT=900.0
# CUSTOM_WRITE_TIMEOUT=900.0
# CUSTOM_POOL_TIMEOUT=900.0

# Force .env values to override env vars passed by the MCP client.
# Recommended true for local dev; false for container/CI deployments.
PAL_MCP_FORCE_ENV_OVERRIDE=true
